generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model accountsReceivable {

  idaccount_receivable          Int      @id @default(autoincrement())
  description                   String
  value                         Float
  idaccount_receivable_category Int
  status                        String
  creation_date                 DateTime @default(now())

  category accountsReceivableCategories @relation(fields: [idaccount_receivable_category], references: [idaccount_receivable_category])

  @@index([idaccount_receivable_category])
  @@map("accounts_receivable")
}

model accountsReceivableCategories {

  idaccount_receivable_category Int @id @default(autoincrement())
  name                          String
  description                   String
  color                         Int

  receivables accountsReceivable[]

  @@map("accounts_receivable_category")
}