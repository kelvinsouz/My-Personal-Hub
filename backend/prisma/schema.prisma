generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model accountsReceivable {

  account_receivable_id          Int      @id @default(autoincrement())
  description                   String
  value                         Float
  account_receivable_category_id Int
  status                        String
  creation_date                 DateTime @default(now())

  category accountsReceivableCategories @relation(fields: [account_receivable_category_id], references: [account_receivable_category_id])

  @@index([account_receivable_category_id])
  @@map("accounts_receivable")
}

model accountsReceivableCategories {

  account_receivable_category_id Int @id @default(autoincrement())
  name                          String
  description                   String
  color                         String

  receivables accountsReceivable[]

  @@map("accounts_receivable_category")
}