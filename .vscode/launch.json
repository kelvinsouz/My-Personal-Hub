{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug NestJS",
            "type": "node",
            "request": "launch",
            "runtimeArgs": [
                "--inspect-brk",
                "-r",
                "ts-node/register"
            ],
            "args": [
                "src/main.ts"
            ],
            "cwd": "${workspaceFolder}",
            "restart": true,
            "console": "integratedTerminal"
        }
    ]
}